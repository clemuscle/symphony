# Overlay pour tester avec GitLab.com.
# 1. Copier en .env.gitlab-com (gitignore)
# 2. Remplir GITLAB_TOKEN et GITLAB_GROUP
# 3. Ajuster config_repo dans config/integrations.gitlab-com.yaml
#
# Usage :
#   cp .env.gitlab-com.example .env.gitlab-com
#   # éditer .env.gitlab-com avec le vrai token
#   set -a && source .env && source .env.gitlab-com && set +a
#   make run

# Token GitLab.com — Personal Access Token, scopes: api + read_registry + write_registry
GITLAB_TOKEN=glpat-XXXXXXXXXXXXXXXXXXXXXXXX

# Charge la config gitlab-com au lieu de la config locale
CONFIG_PATH=config/integrations.gitlab-com.yaml

# Dev mode : pas d'OIDC requis pour les tests locaux
SYMPHONY_DEV_MODE=1

# Port du backend (inchangé)
PORT=8090

# Symphony — démo locale, valeurs non sensibles uniquement.
#
# Usage : cp .env.demo.example .env
#
# Volontairement PAS de GITLAB_URL / GITLAB_TOKEN ici — ces valeurs se
# configurent exclusivement via le wizard Symphony (http://localhost:8090,
# au premier lancement) en suivant DEMO.md. Les pré-remplir ici court-
# circuiterait le wizard et son dispatch par type de provider.

PORT=8090
DB_HOST=localhost
DB_PORT=5432
DB_NAME=symphony
DB_USER=symphony
DB_PASSWORD=symphony123

# Dev local uniquement — jamais en production (désactive l'auth OIDC)
SYMPHONY_DEV_MODE=1

GOLDEN_PATHS_DIR=./config/golden-paths
